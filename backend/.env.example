APP_NAME=陪伴宠物
APP_VERSION=1.0.0
DEBUG=true

# 数据库 (开发使用 SQLite)
DATABASE_URL=sqlite:///./pet_app.db

# LLM API — DeepSeek V4 (Anthropic 兼容接口)
# 从 https://platform.deepseek.com/ 获取
LLM_API_KEY=your_deepseek_api_key_here
LLM_API_BASE=https://api.deepseek.com/anthropic
LLM_MODEL=deepseek-chat

# ASR (语音识别) — 使用 OpenAI Whisper 兼容接口
ASR_API_KEY=
ASR_API_BASE=
ASR_MODEL=whisper-1

# TTS (语音合成) — Edge-TTS 免费，无需 API Key

# FreeSWITCH VoIP (AI 打电话功能)
FS_HOST=localhost
FS_PORT=8021
FS_PASSWORD=ClueCon
SIP_TRUNK=
